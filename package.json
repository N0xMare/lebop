{
  "name": "lebop",
  "version": "0.0.3",
  "description": "Agentic Linear CLI + MCP server for workspace explore/fetch, reviewed publish, guarded cache edits, and markdown plan workflows.",
  "type": "module",
  "license": "MIT",
  "author": "n0x",
  "homepage": "https://github.com/N0xMare/lebop#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/N0xMare/lebop.git"
  },
  "bugs": {
    "url": "https://github.com/N0xMare/lebop/issues"
  },
  "keywords": [
    "linear",
    "linear-app",
    "cli",
    "mcp",
    "model-context-protocol",
    "agent",
    "ai",
    "issue-tracker",
    "graphql",
    "automation",
    "bun"
  ],
  "files": [
    "bin",
    "src",
    "agents",
    "scripts/check-npm-pack.mjs",
    "scripts/install.sh",
    "docs/spec.md",
    "docs/examples",
    "CONTRIBUTING.md",
    "LICENSE",
    "README.md"
  ],
  "bin": {
    "lebop": "./bin/lebop"
  },
  "scripts": {
    "check": "biome check .",
    "check:package": "node scripts/check-npm-pack.mjs",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "bun": ">=1.3.13"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/bun": "^1.3.13",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@linear/sdk": "^86.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.4.0",
    "commander": "^15.0.0",
    "diff": "^9.0.0",
    "yaml": "^2.6.0",
    "zod": "^4.4.3"
  }
}
